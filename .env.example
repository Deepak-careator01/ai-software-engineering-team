# =============================================================================
# AI Software Engineering Team — Environment variable template
# =============================================================================
#
# Setup:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in real values in .env (never commit .env)
#
# Security:
#   - NEXT_PUBLIC_* vars are exposed to the browser — use only for client-safe values
#   - All API keys, service-role keys, and tokens stay in backend-only variables
#   - See docs/architecture.md for security boundaries
#
# Phase 1: Most variables below are placeholders for future phases.
# =============================================================================

# --- Application ---
NODE_ENV=development
APP_ENV=development

# --- Frontend (client-safe — NEXT_PUBLIC_ prefix required) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- Supabase ---
# Anon key is safe for frontend with RLS enabled; service role is backend-only.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- LLM providers (backend only) ---
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
OLLAMA_BASE_URL=http://localhost:11434

# Default provider: gemini | groq | ollama
LLM_PRIMARY_PROVIDER=gemini

# --- GitHub (backend only) ---
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_API_URL=https://api.github.com

# --- Docker sandbox (backend only) ---
DOCKER_SANDBOX_IMAGE=ai-set-sandbox:latest
DOCKER_HOST=unix:///var/run/docker.sock

# --- Logging ---
LOG_LEVEL=INFO
